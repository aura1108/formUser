datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

generator client {
  provider = "prisma-client-js"
}

model UserForm {
  createdAt DateTime @default(now())
  email     String   @unique
  id        String   @id @default(cuid())
  name      String
  pan       String   @unique
  phone     String
  updatedAt DateTime @updatedAt
}
